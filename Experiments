def plot_time_series(
    dfs: Dict[str, pd.DataFrame],
    value_col: str,
    title: str,
    ylabel: str,
):
    plt.figure()
    for name, df in dfs.items():
        plt.plot(df["t"], df[value_col], label=name)
    plt.title(title)
    plt.xlabel("Time")
    plt.ylabel(ylabel)
    plt.legend()
    plt.tight_layout()
    plt.show()


def plot_context(df: pd.DataFrame, title: str = "Context profile"):
    plt.figure()
    plt.plot(df["t"], df["weather"], label="weather")
    plt.plot(df["t"], df["incident"], label="incident")
    plt.plot(df["t"], df["event"], label="event")
    plt.title(title)
    plt.xlabel("Time")
    plt.ylabel("Context intensity")
    plt.legend()
    plt.tight_layout()
    plt.show()


