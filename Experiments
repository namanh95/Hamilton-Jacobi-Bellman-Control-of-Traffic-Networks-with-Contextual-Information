def generate_training_data_for_surrogate(
    params: NetworkParams,
    n_samples: int = 5000,
) -> Tuple[np.ndarray, np.ndarray]:
    """
    Learn a surrogate imitation of the contextual_hjb policy:
    input  -> [q0,q1,q2,q3, demand, weather, incident, event]
    output -> [alpha, meter]
    """
    X, Y = [], []

    for _ in range(n_samples):
        q = np.random.uniform(0.0, params.storage_caps)
        demand = np.random.uniform(10.0, 28.0)
        x = np.random.uniform(0.0, 1.0, size=3)

        u = controller_contextual_hjb(
            q=q,
            demand=demand,
            x_true=x,
            t=0,
            params=params,
            u_prev=np.array([0.5, 1.0]),
            info_mode="full",
            forecast_noise_std=0.0,
        )

        X.append(np.concatenate([q, [demand], x]))
        Y.append(u)

    return np.array(X), np.array(Y)


def experiment_4_surrogate_policy(params: NetworkParams) -> Dict[str, float]:
    print("\n=== Experiment 4: Surrogate-policy timing study ===")

    X, Y = generate_training_data_for_surrogate(params, n_samples=4000)

    X_train, X_test, y_train, y_test = train_test_split(X, Y, test_size=0.20, random_state=42)

    model = MLPRegressor(
        hidden_layer_sizes=(64, 64),
        activation="relu",
        solver="adam",
        max_iter=300,
        random_state=42,
    )

    t0 = time.time()
    model.fit(X_train, y_train)
    train_time = time.time() - t0

    pred = model.predict(X_test)
    imitation_mse = mean_squared_error(y_test, pred)

    # Timing direct HJB-inspired controller vs surrogate
    n_eval = 1000
    eval_states = X_test[:n_eval]

    t0 = time.time()
    for row in eval_states:
        q = row[:4]
        demand = row[4]
        x = row[5:]
        _ = controller_contextual_hjb(
            q=q,
            demand=demand,
            x_true=x,
            t=0,
            params=params,
            u_prev=np.array([0.5, 1.0]),
            info_mode="full",
        )
    direct_time = time.time() - t0

    t0 = time.time()
    _ = model.predict(eval_states)
    surrogate_time = time.time() - t0

    results = {
        "surrogate_train_time_sec": train_time,
        "policy_imitation_mse": imitation_mse,
        "direct_controller_eval_time_sec": direct_time,
        "surrogate_eval_time_sec": surrogate_time,
        "speedup_factor": direct_time / max(surrogate_time, EPS),
    }

    print(results)
    return results


