def experiment_2_throughput_recovery(params: NetworkParams) -> pd.DataFrame:
    print("\n=== Experiment 2: Throughput recovery under persistent degradation ===")

    severities = [0.25, 0.50, 0.75, 1.00]
    controllers = ["static", "state_feedback", "predict_then_optimize", "contextual_hjb"]

    rows = []

    for sev in severities:
        demand, x = make_persistent_degradation_scenario(T=160, severity=sev, kind="mixed")

        for ctrl in controllers:
            cfg = SimConfig(
                T=160,
                demand_profile=demand,
                context_profile=x,
                controller_name=ctrl,
                forecast_noise_std=0.12,
                info_mode="full",
                severity_label=f"{sev:.2f}",
            )
            df = run_simulation(params, cfg)
            s = summarize_performance(df)
            rows.append({
                "severity": sev,
                "controller": ctrl,
                **s.to_dict()
            })

    res = pd.DataFrame(rows)
    print(res.head())

    plt.figure()
    for ctrl in controllers:
        sub = res[res["controller"] == ctrl].sort_values("severity")
        plt.plot(sub["severity"], sub["avg_throughput"], marker="o", label=ctrl)
    plt.title("Experiment 2: Average Throughput vs Disturbance Severity")
    plt.xlabel("Disturbance severity")
    plt.ylabel("Average throughput")
    plt.legend()
    plt.tight_layout()
    plt.show()

    plt.figure()
    for ctrl in controllers:
        sub = res[res["controller"] == ctrl].sort_values("severity")
        plt.plot(sub["severity"], sub["max_queue"], marker="o", label=ctrl)
    plt.title("Experiment 2: Peak Queue vs Disturbance Severity")
    plt.xlabel("Disturbance severity")
    plt.ylabel("Max queue")
    plt.legend()
    plt.tight_layout()
    plt.show()

    return res


