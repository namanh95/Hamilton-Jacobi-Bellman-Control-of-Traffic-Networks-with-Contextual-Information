def experiment_1_transient_stabilization(params: NetworkParams) -> Tuple[pd.DataFrame, Dict[str, pd.DataFrame]]:
    print("\n=== Experiment 1: Stabilization under transient contextual shocks ===")

    T = 120
    demand, x = make_transient_shock_scenario(T=T, severity=0.85)

    all_dfs = {}
    for name in ["no_control", "static", "state_feedback", "predict_then_optimize", "contextual_hjb"]:
        cfg = SimConfig(
            T=T,
            demand_profile=demand,
            context_profile=x,
            controller_name=name,
            forecast_noise_std=0.12,
            info_mode="full",
            severity_label="transient_high",
        )
        df = run_simulation(params, cfg)
        all_dfs[name] = df

    summary = pd.concat(
        {name: summarize_performance(df) for name, df in all_dfs.items()},
        axis=1
    ).T

    print(summary.sort_values("total_queue"))

    plot_context(next(iter(all_dfs.values())), title="Experiment 1 Context Profile")
    plot_time_series(all_dfs, "queue_total", "Experiment 1: Total Queue Length", "Total queue")
    plot_time_series(all_dfs, "throughput", "Experiment 1: Network Throughput", "Throughput")
    plot_time_series(all_dfs, "stage_cost", "Experiment 1: Stage Cost", "Stage cost")

    return summary, all_dfs


