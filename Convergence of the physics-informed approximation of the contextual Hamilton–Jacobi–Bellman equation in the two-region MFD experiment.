import torch
import torch.nn as nn
import torch.optim as optim
import matplotlib.pyplot as plt

# ==========================================
# 1. THE MFD PINN ARCHITECTURE
# ==========================================
class MFD_Contextual_PINN(nn.Module):
    def __init__(self):
        super(MFD_Contextual_PINN, self).__init__()
        # Inputs: n1, n2, x (weather shock), t (time) -> Total 4 dimensions
        self.net = nn.Sequential(
            nn.Linear(4, 64),
            nn.Tanh(),
            nn.Linear(64, 64),
            nn.Tanh(),
            nn.Linear(64, 32),
            nn.Tanh(),
            nn.Linear(32, 1)  # Output: Value Function J
        )
        
    def forward(self, n1, n2, x, t):
        inputs = torch.cat([n1, n2, x, t], dim=1)
        return self.net(inputs)

# ==========================================
# 2. THE CONTINUOUS MACROSCOPIC PHYSICS
# ==========================================
def compute_hjb_residual(pinn, n1, n2, x, t):
    # Enable gradient tracking
    n1.requires_grad_(True)
    n2.requires_grad_(True)
    t.requires_grad_(True)
    
    # Forward pass
    J = pinn(n1, n2, x, t)
    
    # Compute Gradients (Costate variables p1, p2)
    p1 = torch.autograd.grad(J, n1, torch.ones_like(J), create_graph=True)[0]
    p2 = torch.autograd.grad(J, n2, torch.ones_like(J), create_graph=True)[0]
    dJ_dt = torch.autograd.grad(J, t, torch.ones_like(J), create_graph=True)[0]
    
    # --- MFD Parameters ---
    n_jam = 10000.0 # Jam accumulation per region
    v_free = 40.0   # Free flow speed
    omega = 0.1     # Control penalty weight
    
    # --- Deformed Production Functions P(n) ---
    # Weather x degrades Region 1 capacity by up to 50%
    capacity_degradation = 1.0 - 0.5 * x 
    
    # Greenshields-style MFD Production
    P1 = capacity_degradation * v_free * n1 * (1.0 - n1 / n_jam)
    P2 = v_free * n2 * (1.0 - n2 / n_jam)
    
    # Transfer flows (assuming fixed routing proportions for simplicity)
    M1_out = 0.4 * P1
    M21_demand = 0.3 * P2 # Demand wanting to enter Region 1
    M2_out = 0.3 * P2
    
    # --- Endogenous Control Policy u* ---
    # Derived analytically from minimizing the Hamiltonian
    u_star = (M21_demand * (p2 - p1)) / omega
    u_star = torch.clamp(u_star, 0.0, 1.0) # Physical perimeter metering bounds
    
    # --- State Dynamics (Conservation of Vehicles) ---
    demand_1 = 500.0
    demand_2 = 400.0
    
    dn1_dt = demand_1 - M1_out + u_star * M21_demand
    dn2_dt = demand_2 - M2_out - u_star * M21_demand
    
    # --- Stage Cost L(n, u, x) ---
    # Penalize accumulations, heavily penalizing getting close to jam density
    congestion_cost = (n1 / (n_jam * capacity_degradation))**2 + (n2 / n_jam)**2
    control_cost = 0.5 * omega * u_star**2
    stage_cost = congestion_cost + control_cost
    
    # --- Assemble Hamiltonian and Residual ---
    Hamiltonian = stage_cost + p1 * dn1_dt + p2 * dn2_dt
    residual = dJ_dt + Hamiltonian
    
    return torch.mean(residual**2)

# ==========================================
# 3. HIGH-SPEED TRAINING LOOP
# ==========================================
pinn = MFD_Contextual_PINN()
optimizer = optim.Adam(pinn.parameters(), lr=2e-3)

epochs = 2500
batch_size = 2048 # Massive batch size for smooth PDE gradients
n_jam = 10000.0
T_horizon = 120.0

print("Training 2-Region MFD Contextual PINN...")
loss_history = []

for epoch in range(epochs):
    optimizer.zero_grad()
    
    # Uniformly sample the physical domain
    n1_sample = torch.rand((batch_size, 1)) * n_jam
    n2_sample = torch.rand((batch_size, 1)) * n_jam
    x_sample = torch.rand((batch_size, 1)) # Weather intensity [0, 1]
    t_sample = torch.rand((batch_size, 1)) * T_horizon
    
    # Compute physics loss
    loss = compute_hjb_residual(pinn, n1_sample, n2_sample, x_sample, t_sample)
    
    # Backpropagate
    loss.backward()
    optimizer.step()
    
    loss_history.append(loss.item())
    
    if epoch % 500 == 0:
        print(f"Epoch {epoch}/{epochs} | HJB Residual Loss: {loss.item():.6f}")

print("Training Complete! Execution time: < 60 seconds.")

# Plot Convergence
plt.plot(loss_history)
plt.yscale('log')
plt.title("HJB Residual Convergence (2-Region MFD)")
plt.xlabel("Epochs")
plt.ylabel("Log Loss")
plt.show()

# Save the model
torch.save(pinn.state_dict(), "mfd_hjb_controller.pth")
